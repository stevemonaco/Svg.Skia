<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Svg.Editor.Avalonia.Controls.StatusBarView">
    <Border Background="#EEE" Padding="4">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="StatusTextBlockControl" Margin="4" />
            <Button x:Name="ResetButtonControl" Content="Reset" Margin="4,0" />
        </StackPanel>
    </Border>
</UserControl>
